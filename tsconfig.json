{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "out",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "types": ["node", "mocha", "vscode"],
    "skipLibCheck": true
  },
  "include": ["src"]
}
